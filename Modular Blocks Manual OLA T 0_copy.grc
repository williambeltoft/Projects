      ''0.0002''), (''spec_nperseg'', ''1024''), (''spec_overlap'', ''819'')], [(''0'',
      ''complex'', 1)], [(''jammer_params_out'', ''message'', 1)], ''\n    Estimator
      Block: Buffers samples, estimates jammer parameters once, \n    and emits a
      PMT message.\n    '', [''acquisition_chunk_size'', ''f_samplerate'', ''spec_nperseg'',
      ''spec_overlap'', ''start_idx'', ''taper_sec''])'
