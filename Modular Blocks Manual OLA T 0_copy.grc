- name: epy_block_0_0_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nfrom scipy.ndimage\
      \ import gaussian_filter1d\n\nclass ChirpJammerSource(gr.sync_block):\n    \"\
      \"\"\n    Chirp Jammer Source: Generates a continuous Linear FM (Chirp) signal.\n\
      \    \"\"\"\n    def __init__(self, f_samplerate=2560000.0, f_start=-1.25e6,\
      \ f_stop=1.25e6, sweep_time=0.01, amplitude=1.0, jitter_std=0.0, taper_ratio=0.1):\n\
      \        gr.sync_block.__init__(\n            self,\n            name='Chirp\
      \ Jammer Source',\n            in_sig=None,         # This is a source block,\
      \ so no input signal\n            out_sig=[np.complex64]\n        )\n      \
      \  \n        self.f_samplerate = float(f_samplerate)\n        self.f_start =\
      \ float(f_start)\n        self.f_stop = float(f_stop)\n        self.sweep_time\
      \ = float(sweep_time)\n        self.amplitude = float(amplitude)\n        self.jitter_std\
      \ = float(jitter_std)\n        self.taper_ratio = float(taper_ratio)\n     \
      \   \n        # Explicitly calculate chirp rate so it remains constant across\
      \ unpredictable GRC chunk sizes\n        self.chirp_rate = (self.f_stop - self.f_start)\
      \ / self.sweep_time\n        \n        # Track global time for continuous phase\
      \ accumulation\n        self.n_samples_generated = 0\n\n    @staticmethod\n\
      \    def create_linear_FM_signal(freqs, t_vec, f_samplerate, amplitude, chirp_rate,\
      \ jitter_std=0.0, taper_ratio=0.0):\n        \"\"\"\n        User-provided LFM\
      \ generator.\n        \"\"\"\n        sweep_duration = (freqs[-1] - freqs[0])\
      \ / chirp_rate\n        \n        cycle_number = np.floor(t_vec / sweep_duration).astype(int)\n\
      \        t_in_sweep = t_vec - (cycle_number * sweep_duration)\n        \n  \
      \      phase_in_sweep = 2 * np.pi * (freqs[0] * t_in_sweep + 0.5 * chirp_rate\
      \ * (t_in_sweep**2))\n        phase_per_cycle = 2 * np.pi * (freqs[0] * sweep_duration\
      \ + 0.5 * chirp_rate * (sweep_duration**2))\n        phase_accumulated = cycle_number\
      \ * phase_per_cycle\n        \n        phase = phase_in_sweep + phase_accumulated\n\
      \        \n        if jitter_std > 0:\n            white_noise = np.random.normal(loc=0.0,\
      \ scale=jitter_std, size=len(t_vec))\n            freq_noise_Hz = gaussian_filter1d(white_noise,\
      \ sigma=100) \n            \n            current_std = np.std(freq_noise_Hz)\n\
      \            if current_std > 0:\n                freq_noise_Hz = freq_noise_Hz\
      \ * (jitter_std / current_std)\n\n            dt = 1.0 / f_samplerate\n    \
      \        phase_jitter = 2 * np.pi * np.cumsum(freq_noise_Hz) * dt\n        \
      \    phase += phase_jitter\n        \n        norm_t = t_in_sweep / sweep_duration\n\
      \        envelope = np.ones_like(norm_t)\n        \n        if taper_ratio >\
      \ 0:\n            edge_width = taper_ratio / 2.0\n            \n           \
      \ mask_rise = norm_t < edge_width\n            envelope[mask_rise] = 0.5 * (1\
      \ - np.cos(np.pi * norm_t[mask_rise] / edge_width))\n            \n        \
      \    mask_fall = norm_t > (1 - edge_width)\n            envelope[mask_fall]\
      \ = 0.5 * (1 - np.cos(np.pi * (1 - norm_t[mask_fall]) / edge_width))\n\n   \
      \         signal = amplitude * envelope * np.exp(1j * phase)\n        else:\
      \     \n            signal = amplitude * np.exp(1j * phase)\n\n        return\
      \ signal\n\n    def work(self, input_items, output_items):\n        out = output_items[0]\n\
      \        n_output_items = len(out)\n        \n        # 1. Generate the exact\
      \ continuous global time slice for this specific chunk\n        t_vec = (self.n_samples_generated\
      \ + np.arange(n_output_items)) / self.f_samplerate\n        \n        # 2. Call\
      \ the generator\n        signal = self.create_linear_FM_signal(\n          \
      \  freqs=[self.f_start, self.f_stop],\n            t_vec=t_vec,\n          \
      \  f_samplerate=self.f_samplerate,\n            amplitude=self.amplitude,\n\
      \            chirp_rate=self.chirp_rate,\n            jitter_std=self.jitter_std,\n\
      \            taper_ratio=self.taper_ratio\n        )\n        \n        # 3.\
      \ Output the signal and advance the clock\n        out[:] = signal.astype(np.complex64)\n\
      \        self.n_samples_generated += n_output_items\n        \n        return\
      \ n_output_items"
    affinity: ''
    alias: ''
    amplitude: '100'
    comment: ''
    f_samplerate: samp_rate
    f_start: f_start
    f_stop: f_stop
    jitter_std: '0.001'
    maxoutbuf: '0'
    minoutbuf: '0'
    sweep_time: '0.01'
    taper_ratio: '0.005'
  states:
    _io_cache: '(''Chirp Jammer Source'', ''ChirpJammerSource'', [(''f_samplerate'',
      ''2560000.0''), (''f_start'', ''-1250000.0''), (''f_stop'', ''1250000.0''),
      (''sweep_time'', ''0.01''), (''amplitude'', ''1.0''), (''jitter_std'', ''0.0''),
      (''taper_ratio'', ''0.1'')], [], [(''0'', ''complex'', 1)], ''\n    Chirp Jammer
      Source: Generates a continuous Linear FM (Chirp) signal.\n    '', [''amplitude'',
      ''f_samplerate'', ''f_start'', ''f_stop'', ''jitter_std'', ''sweep_time'', ''taper_ratio''])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [152, 416.0]
    rotation: 0
    state: enabled
- name: epy_block_0_0_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nfrom scipy.signal\
      \ import correlate\n\nclass NormalizedPeakCorrelator(gr.sync_block):\n    \"\
      \"\"\n    Takes a reference vector and a target vector, computes the FFT-based\
      \ cross-correlation, \n    normalizes it by the energy of both signals, and\
      \ outputs the maximum peak as a float (0 to 1).\n    \"\"\"\n    def __init__(self,\
      \ vector_length=2048):\n        gr.sync_block.__init__(\n            self,\n\
      \            name='Normalized Peak Correlator',\n            in_sig=[(np.complex64,\
      \ vector_length), (np.complex64, vector_length)],\n            out_sig=[np.float32]\n\
      \        )\n\n    def work(self, input_items, output_items):\n        ref_vectors\
      \ = input_items[1]\n        sig_vectors = input_items[0]\n        out = output_items[0]\n\
      \n        for i in range(len(ref_vectors)):\n            ref = ref_vectors[i]\n\
      \            sig = sig_vectors[i]\n            \n            # 1. Compute cross-correlation\n\
      \            corr = correlate(ref, sig, mode='full', method='fft')\n       \
      \     \n            # 2. Compute signal energies\n            energy_ref = np.sum(np.abs(ref)**2)\n\
      \            energy_sig = np.sum(np.abs(sig)**2)\n            \n           \
      \ # 3. Normalize and extract the peak\n            if energy_ref == 0 or energy_sig\
      \ == 0:\n                out[i] = 0.0\n            else:\n                norm_factor\
      \ = np.sqrt(energy_ref * energy_sig)\n                out[i] = float(np.max(np.abs(corr))\
      \ / norm_factor)\n\n        return len(output_items[0])"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    vector_length: '2048'
  states:
    _io_cache: ('Normalized Peak Correlator', 'NormalizedPeakCorrelator', [('vector_length',
      '2048')], [('0', 'complex', 2048), ('1', 'complex', 2048)], [('0', 'float',
      1)], '\n    Takes a reference vector and a target vector, computes the FFT-based
      cross-correlation, \n    normalizes it by the energy of both signals, and outputs
      the maximum peak as a float (0 to 1).\n    ', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1832, 924.0]
    rotation: 0
    state: enabled
- name: epy_block_1
  id: epy_block
  parameters:
    PRN: '27'
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      from gnuradio import gr\n\n\nclass blk(gr.sync_block):\n    \"\"\"GPS L1 C/A\
      \ Gold code generator\"\"\"\n\n    def __init__(self, PRN=1, samp_rate=1.023e6):\n\
      \n        gr.sync_block.__init__(\n            self,\n            name='Gold\
      \ Code Generator',\n            in_sig=None,\n            out_sig=[np.complex64]\n\
      \        )\n\n        self.PRN = int(PRN)\n        self.samp_rate = float(samp_rate)\n\
      \        self.chips = 1.023e6\n        self.samples_per_code = int(round(1023\
      \ * self.samp_rate/self.chips))\n        self.g2s = [5, 6, 7, 8, 17, 18, 139,\
      \ 140, 141, 251, 252, 254, \n                    255, 256, 257, 258, 469, 470,\
      \ 471, 472, 473, 474, \n                    509, 512, 513, 514, 515, 516, 859,\
      \ 860,861, 862, \n                    145, 175, 52, 21, 237, 235, 886, 657,\
      \ 634, 762, \n                    355, 1012, 176, 603, 130, 359, 595, 68, 386]\n\
      \n        # Precompute the full 1023-chip CA code once\n        # self.code\
      \ = self._generate_code(self.PRN).astype(np.complex64)\n        self.idx = 0\
      \   # current position in the sequence (chip counter)\n\n    def _generate_code(self,\
      \ prn):\n\n        g2shift = self.g2s[prn-1]\n\n        # Generate G1 code.\n\
      \        # Initialize g1 output to speed up the function.\n        g1 = [0]\
      \ * 1023\n        # Load shift register.\n        reg = [-1] * 10\n        #\
      \ Generate all G1 signal chips based on the G1 feedback polynomial.\n      \
      \  for i in range(1023):\n            g1[i] = reg[9]\n            saveBit =\
      \ reg[2] * reg[9]\n            reg[1:10] = reg[0:9]\n            reg[0] = saveBit\n\
      \n        # Generate G2 code.\n        # Initialize g2 output to speed up the\
      \ function.\n        g2 = [0] * 1023\n        # Load shift register.\n     \
      \   reg = [-1] * 10\n        # Generate all G2 signal chips based on the G2\
      \ feedback polynomial.\n        for i in range(1023):\n            g2[i] = reg[9]\n\
      \            saveBit = reg[1] * reg[2] * reg[5] * reg[7] * reg[8] * reg[9]\n\
      \            reg[1:10] = reg[0:9]\n            reg[0] = saveBit\n\n        #\
      \ Shift\n        g2 = g2[1023-g2shift:1023] + g2[0:1023-g2shift]\n\n       \
      \ # Gold code\n        return np.array([-1 * g1[i] * g2[i] for i in range(1023)])\n\
      \n    def work(self, input_items, output_items):\n        out = output_items[0]\n\
      \        n = len(out)\n\n        code = self._generate_code(self.PRN).astype(np.complex64)\n\
      \n        for i in range(n):\n\n            chip_index = int((self.idx * self.chips)\
      \ / self.samp_rate)\n\n            out[i] = code[chip_index % 1023]\n      \
      \      self.idx += 1\n            if self.idx >= 1023 * self.samples_per_code:\n\
      \                self.idx = 0\n\n        return n\n\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    samp_rate: samp_rate
  states:
    _io_cache: ('Gold Code Generator', 'blk', [('PRN', '1'), ('samp_rate', '1023000.0')],
      [], [('0', 'complex', 1)], 'GPS L1 C/A Gold code generator', ['PRN', 'samp_rate'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [168, 912.0]
    rotation: 0
    state: enabled
